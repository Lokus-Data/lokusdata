# Google Ads API — copia este archivo a .env y rellena los valores
# Guía completa: docs/GOOGLE-ADS-SETUP.md

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Customer ID de la cuenta donde corren los anuncios (sin guiones)
# Ejemplo: 1234567890  (NO 123-456-7890)
GOOGLE_ADS_CUSTOMER_ID=

# Si usas una cuenta MCC (manager) — deja vacío si NO usas MCC
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ID del Ad Group donde se agregarán los anuncios nuevos
# Lo obtienes desde Google Ads UI → Grupos de anuncios → click → URL contiene adGroupId=XXXX
GOOGLE_ADS_AD_GROUP_ID=
